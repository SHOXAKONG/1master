# Copy this to .env on your VPS and fill in the values

# Your GitHub repo (e.g., shohruhbek/mytunnel)
GITHUB_REPO=your-github-username/mytunnel

# Your tunnel domain
TUNNEL_DOMAIN=tunnel.yourdomain.com

# Cloudflare API token (for wildcard TLS certs)
CF_API_TOKEN=your-cloudflare-api-token

# Email for Let's Encrypt
ACME_EMAIL=you@example.com
